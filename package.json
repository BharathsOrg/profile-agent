{
  "name": "adk-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:agent": "./scripts/run-agent.sh || scripts/run-agent.bat",
    "dev:ui": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "install:agent": "./scripts/setup-agent.sh || scripts\\setup-agent.bat",
    "postinstall": "npm run install:agent"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.52",
    "@chakra-ui/react": "3.34.0",
    "@copilotkit/react-core": "1.51.2",
    "@copilotkit/react-textarea": "1.51.2",
    "@copilotkit/react-ui": "1.51.2",
    "@copilotkit/runtime": "1.51.2",
    "@elevenlabs/react": "^1.2.1",
    "@emotion/react": "11.14.0",
    "lucide-react": "0.563.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "3.22.0",
    "zod": "3.25.76"
  },
  "overrides": {
    "@ag-ui/client": "0.0.52",
    "@ag-ui/core": "0.0.52",
    "@ag-ui/proto": "0.0.52",
    "@ag-ui/encoder": "0.0.52"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "20.19.33",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  }
}
